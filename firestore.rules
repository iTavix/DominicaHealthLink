rules_version = '2';

// =============================================================================
//  DominicaHealthLink — Firestore Security Rules
//  These rules are the REAL security boundary for your data. The role checks in
//  the web app (admin/operator) are only UI convenience; enforcement happens HERE.
//  Deploy with:  firebase deploy --only firestore:rules
// =============================================================================
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() { return request.auth != null; }
    function isOwner(userId) { return isSignedIn() && request.auth.uid == userId; }
    // Role via Firebase custom claim, set server-side (see scripts/set-admin-claim.js).
    // Still honored, but no longer required: see the access map below.
    function isAdmin() { return isSignedIn() && request.auth.token.role == 'admin'; }
    function isOperator() { return isSignedIn() && (request.auth.token.role == 'operator' || isAdmin()); }

    // ---- Access map (managed from the app, no server script needed) ----
    // organizations/{org}/data/access holds { emails: { "person@x.com": "admin"|"operator" } },
    // written by the app whenever an admin edits the HR operators list. A signed-in user
    // whose login email appears there is authorized with that role. Custom claims keep
    // working as an override (and are what bootstrapped the first admin).
    function accessData(orgId) {
      return get(/databases/$(database)/documents/organizations/$(orgId)/data/access).data;
    }
    function inAccess(orgId) {
      return isSignedIn()
        && request.auth.token.email != null
        && exists(/databases/$(database)/documents/organizations/$(orgId)/data/access)
        && request.auth.token.email.lower() in accessData(orgId).emails;
    }
    function canOperate(orgId) { return isOperator() || inAccess(orgId); }
    function canAdminOrg(orgId) {
      return isAdmin() || (inAccess(orgId) && accessData(orgId).emails[request.auth.token.email.lower()] == 'admin');
    }

    // ---- Per-user private workspace (the app's current data model) ----
    // Every user can read/write ONLY their own document. No one else, and no
    // unauthenticated access, can ever read it. Each document holds that user's
    // whole app state under { state, updatedAt }.
    match /nurseflow/{userId} {
      allow read:  if isOwner(userId);
      allow write: if isOwner(userId) && request.resource.size() < 1048576; // ~1 MB safety cap
    }

    // ---- Shared team workspace (active when the app's SHARED_WORKSPACE = true) ----
    // The whole HR team shares the SAME data, split into two documents with different
    // permissions. Requires the 'role' custom claim (see scripts/set-admin-claim.js).
    //   data/cases    → the candidate caseload: any operator (or admin) may read & write.
    //   data/settings → base records (agencies, employers, operators, document types):
    //                   everyone reads, ONLY admins write. This is what makes the
    //                   admin/operator distinction real and unbypassable.
    match /organizations/{orgId}/data/cases {
      allow read:  if canOperate(orgId);
      allow write: if canOperate(orgId) && request.resource.size() < 1048576;
    }
    match /organizations/{orgId}/data/settings {
      allow read:  if canOperate(orgId);
      allow write: if canAdminOrg(orgId) && request.resource.size() < 1048576;
    }
    // The access map itself: everyone in the team can read it, only admins write it.
    match /organizations/{orgId}/data/access {
      allow read:  if canOperate(orgId);
      allow write: if canAdminOrg(orgId) && request.resource.size() < 1048576;
    }

    // ---- Document files stored in Firestore (free plan, no Firebase Storage) ----
    // Each uploaded file is split into base64 chunks of < 1 MB, one document per
    // chunk. Same access rules as the case data they belong to.
    match /organizations/{orgId}/files/{chunkId} {
      allow read, delete: if canOperate(orgId);
      allow create, update: if canOperate(orgId) && request.resource.size() < 1048576;
    }
    match /nurseflow/{userId}/files/{chunkId} {
      allow read, delete: if isOwner(userId);
      allow create, update: if isOwner(userId) && request.resource.size() < 1048576;
    }

    // ---- Deny everything else by default ----
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
