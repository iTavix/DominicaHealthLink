rules_version = '2';

// =============================================================================
//  DominicaHealthLink — Firebase Storage Security Rules
//  Controls who can upload/read the actual document files (PDFs, scans, photos).
//  Enable Storage in the Firebase console first, then deploy with:
//    firebase deploy --only storage
// =============================================================================
service firebase.storage {
  match /b/{bucket}/o {

    function isSignedIn() { return request.auth != null; }
    function isAdmin() { return isSignedIn() && request.auth.token.role == 'admin'; }
    function isOperator() { return isSignedIn() && (request.auth.token.role == 'operator' || isAdmin()); }
    // Allow common document/image types up to 20 MB.
    function okFile() {
      return request.resource.size < 20 * 1024 * 1024
        && request.resource.contentType.matches('application/pdf|image/.*|application/msword|application/vnd.openxmlformats-officedocument.*');
    }

    // Per-user private files (when SHARED_WORKSPACE = false): only the owner.
    match /documents/users/{userId}/{allPaths=**} {
      allow read:  if isSignedIn() && request.auth.uid == userId;
      allow write: if isSignedIn() && request.auth.uid == userId && okFile();
    }

    // Shared team files (when SHARED_WORKSPACE = true): any operator can read/upload.
    match /documents/org/{orgId}/{allPaths=**} {
      allow read:  if isOperator();
      allow write: if isOperator() && okFile();
    }

    // Deny everything else.
    match /{allPaths=**} { allow read, write: if false; }
  }
}
